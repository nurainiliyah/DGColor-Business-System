@model DgAPI.Models.PrintingOrder

<h2>Delete Print Order</h2>

<h3>Are you sure you want to delete this order?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">
            Customer Name
        </dt>
        <dd class="col-sm-10">
            @Model.customer_id
        </dd>
        <dt class="col-sm-2">
            Print Service
        </dt>
        <dd class="col-sm-10">
            @Model.printingservice_id
        </dd>
        <dt class="col-sm-2">
            Quantity
        </dt>
        <dd class="col-sm-10">
            @Model.printing_quantity
        </dd>
        <dt class="col-sm-2">
            Total Price
        </dt>
        <dd class="col-sm-10">
            @Model.print_totalprice
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="printingorder_id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
