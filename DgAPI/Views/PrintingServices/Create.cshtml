@model DgAPI.Models.PrintingService

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow p-4">
                <h4 class="text-center">Add New Print Service</h4>
<form asp-action="Create" method="post">
    <div class="form-group">
        <label class="control-label">Service Name</label>
        <input asp-for="printingservice_name" class="form-control" />
        <span asp-validation-for="printingservice_name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label class="control-label">Size</label>
        <input asp-for="printing_size" class="form-control" />
        <span asp-validation-for="printing_size" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label class="control-label">Price</label>
                        <div>
                            <div class="input-group mb-3">
                                <span class="input-group-text">RM</span>
        <input asp-for="printing_price" class="form-control" />
        <span asp-validation-for="printing_price" class="text-danger"></span>
                            </div>
                        </div>
    </div>
    <div class="form-group">
        <label class="control-label">Status</label>
                        <select asp-for="printing_status" class="form-select">
                            <option value="">-- Select Status --</option>
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
        <span asp-validation-for="printing_status" class="text-danger"></span>
    </div>
        <br />
    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
            </div>
        </div>
    </div>
</div>