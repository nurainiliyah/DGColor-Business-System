@model DgAPI.Models.PrintingService

<h2>Delete Print Service</h2>

<h3>Are you sure you want to delete this service?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">
            Print Service Name
        </dt>
        <dd class="col-sm-10">
            @Model.printingservice_name
        </dd>
        <dt class="col-sm-2">
            Size
        </dt>
        <dd class="col-sm-10">
            @Model.printing_size
        </dd>
        <dt class="col-sm-2">
            Price
        </dt>
        <dd class="col-sm-10">
            @Model.printing_price
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="printingservice_id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
