@model DgAPI.Models.StudioBooking

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow p-4">
                <h4 class="text-center">Edit Booking</h4>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="booking_id" id="booking_id"/> <!-- Hidden field to store BookingID -->
    <input type="hidden" asp-for="customer_id" />

                    <div class="form-group">
                        <label>Customer</label>
                        <input value="@Model.customers?.customer_name" class="form-control" readonly />
                    </div>
                    <div class="form-group">
                        <label>Package</label>

                        <select asp-for="package_id"
                                asp-items="ViewBag.PackageList"
                                class="form-control">
                            <option value="">-- Select Package --</option>
                        </select>

                        <span asp-validation-for="package_id" class="text-danger"></span>
                    </div>
    <div class="form-group">
        <label class="control-label">Date</label>
                        <input asp-for="booking_date" id="booking_date" class="form-control" type="date" />
        <span asp-validation-for="booking_date" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label class="control-label">Time</label>
                        <input asp-for="booking_time" id="booking_time" class="form-control" type="time" />
        <span asp-validation-for="booking_time" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label class="control-label">Note</label>
        <input asp-for="note" class="form-control" />
        <span asp-validation-for="note" class="text-danger"></span>
    </div>
                    <br />
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>

</form>
                <br />
                <!-- Delete Booking -->
                <form asp-action="DeleteConfirmed" method="post" onsubmit="return confirm('Are you sure you want to delete this booking?');">
                    <input type="hidden" asp-for="booking_id" />
                    <button type="submit" class="btn btn-danger">Delete Booking</button>
                </form>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const dateInput = document.querySelector("#booking_date");
        const timeInput = document.querySelector("#booking_time");
        const bookingId = document.querySelector("#booking_id").value;

        function checkAvailability() {

            const date = dateInput.value;
            const time = timeInput.value;

            if (!date || !time) return;

            fetch(`/StudioBookings/CheckAvailability?date=${date}&time=${time}&bookingId=${bookingId}`)
            .then(response => response.json())
            .then(data => {

                let warning = document.getElementById("time-warning");

                if (!warning) {
                    warning = document.createElement("div");
                    warning.id = "time-warning";
                    warning.style.color = "red";
                    timeInput.parentNode.appendChild(warning);
                }

                if (!data.available) {
                    warning.innerText = "⚠ This time slot is already booked!";
                } else {
                    warning.innerText = "";
                }

            });
        }

        dateInput.addEventListener("change", checkAvailability);
        timeInput.addEventListener("change", checkAvailability);

    });
</script>