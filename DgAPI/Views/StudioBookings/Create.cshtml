@model DgAPI.Models.StudioBooking

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow p-4">
                <h4 class="text-center">Add New Studio Booking</h4>
                
<form asp-action="Create" method="post">
                    <div class="form-group">
                        <label>Search Customer</label>

                        <input type="text"
                               id="customerSearch"
                               class="form-control"
                               placeholder="Type customer name..." />

                        <div id="customerResults" class="list-group mt-2"></div>

                        <!-- MUST be inside the form -->
                        <input type="hidden"
                               asp-for="customer_id"
                               id="customerId" />
                    </div>
                    <div class="form-group mt-3">
                        <label>Package</label>

                        <select asp-for="package_id"
                                asp-items="ViewBag.PackageList"
                                class="form-control">
                            <option value="">-- Select Package --</option>
                        </select>

                        <span asp-validation-for="package_id" class="text-danger"></span>
                    </div>
                    <div class="form-group">
        <label class="control-label">Date</label>
                        <input asp-for="booking_date" class="form-control" type="date" value="@(ViewBag.SelectedDate != null
                                                                                                  ? ((DateOnly)ViewBag.SelectedDate).ToString("yyyy-MM-dd")
                                                                                                  : "")" />
        <span asp-validation-for="booking_date" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label class="control-label">Time</label>
        <input asp-for="booking_time" class="form-control" type="time"/>
        <span asp-validation-for="booking_time" class="text-danger"></span>
                        <div id="timeStatus" class="mt-2"></div>
    </div>
    <div class="form-group">
        <label class="control-label">Note</label>
        <input asp-for="note" class="form-control" />
        <span asp-validation-for="note" class="text-danger"></span>
    </div>
                    <br />
    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
            </div>
        </div>
    </div>
</div>
<script>
        document.querySelector("form").addEventListener("submit", function(e){

        let customerId = document.getElementById("customerId").value;

        if(!customerId){
            alert("Please select a customer first.");
            e.preventDefault();
        }

    });
    document.getElementById("customerSearch").addEventListener("keyup", function () {

        let search = this.value;

        if (search.length < 2) {
            document.getElementById("customerResults").innerHTML = "";
            return;
        }

        fetch(`/StudioBookings/SearchCustomer?term=${search}`)
            .then(response => response.json())
            .then(data => {

                let results = "";

                data.forEach(customer => {
                    results += `
                        <a href="#" class="list-group-item list-group-item-action"
                           onclick="selectCustomer(${customer.id}, '${customer.name}')">
                            ${customer.name}
                        </a>
                    `;
                });

                document.getElementById("customerResults").innerHTML = results;
            });
    });

        document.getElementById("bookingTime").addEventListener("change", checkAvailability);
    document.getElementById("booking_date").addEventListener("change", checkAvailability);

        function checkAvailability(){
        let date = document.getElementById("booking_date").value;
        let time = document.getElementById("bookingTime").value;
        let submitBtn = document.querySelector("button[type='submit']");
        let status = document.getElementById("timeStatus");

        if(!date || !time) return;

        fetch(`/StudioBookings/CheckAvailability?date=${date}&time=${time}`)
        .then(response => response.json())
        .then(data => {
            if(data.available){
                status.innerHTML = "<span style='color:green'>✅ Time slot available</span>";
                submitBtn.disabled = false;
            }
            else{
                status.innerHTML = "<span style='color:red'>❌ Time slot already booked</span>";
                submitBtn.disabled = true;
            }
        });
    }
    function selectCustomer(id, name) {

        document.getElementById("customerSearch").value = name;
        document.getElementById("customerId").value = id;
        document.getElementById("customerResults").innerHTML = "";
    }
</script>
