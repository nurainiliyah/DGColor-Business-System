@model DgAPI.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4">Dashboard</h2>
<div class="shadow-sm p-3 rounded text-white"
     style="background: linear-gradient(to right, #ff69b4, #ff85c1);">
    <h5 class="mb-0">
        Welcome back, <strong>@User.Identity.Name</strong>
    </h5>
</div>
<br/>
<div class="row mb-4">
    <!-- Total Revenue -->
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3 shadow">
            <div class="card-body text-center">
                <h5 class="card-title">Total Revenue</h5>
                <h3>RM @ViewBag.TotalRevenue</h3>
            </div>
        </div>
    </div>

    <!-- Booking Revenue -->
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3 shadow">
            <div class="card-body text-center">
                <h5 class="card-title">Booking Revenue</h5>
                <h3>RM @ViewBag.BookingRevenue</h3>
            </div>
        </div>
    </div>

    <!-- Printing Revenue -->
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3 shadow">
            <div class="card-body text-center">
                <h5 class="card-title">Printing Revenue</h5>
                <h3>RM @ViewBag.PrintingRevenue</h3>
            </div>
        </div>
    </div>

    <br />
    <!-- Total Sales Today -->
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3 shadow">
            <div class="card-body text-center">
                <h5>Total Sales Today</h5>
                <h3>RM @(ViewBag.TotalSalesToday ?? 0)</h3>
            </div>
        </div>
    </div>
    </div>
<!-- Charts -->
    <div class="row mb-4">
        <!-- Monthly Revenue Trend (Combined Booking + Printing) -->
        <div class="card shadow-sm w-100">
            <div class="card-header text-center">
                <h5>Monthly Revenue Trend</h5>
            </div>
            <div class="card-body">
                <canvas id="monthlyRevenueChart" height="100"></canvas>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <!-- Bookings per Package -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5>Bookings per Package</h5>
                </div>
                <div style="width:300px; margin:auto;" class="card-body">
                    <canvas id="packageBookingsChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Printing Orders per Service -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5>Printing Orders per Service</h5>
                </div>
                <div style="width:300px; margin:auto;" class="card-body">
                    <canvas id="printingServiceChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels"></script>

    <script>
        // Monthly Revenue Line Chart
        new Chart(document.getElementById("monthlyRevenueChart"), {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.MonthlyLabels)),
                datasets: [
                    {
                        label: 'Studio Bookings',
                        data: @Html.Raw(Json.Serialize(ViewBag.MonthlyBookingCounts)),
                        borderColor: 'rgba(75, 192, 192, 1)',
                        backgroundColor: 'rgba(75, 192, 192, 0.2)',
                        tension: 0.3,
                        fill: false,
                        borderWidth: 3,
                        pointRadius: 4
                    },
                    {
                        label: 'Printing Orders',
                        data: @Html.Raw(Json.Serialize(ViewBag.MonthlyPrintingCounts)),
                        borderColor: 'rgba(255, 159, 64, 1)',
                        backgroundColor: 'rgba(255, 159, 64, 0.2)',
                        tension: 0.3,
                        fill: false,
                        borderWidth: 3,
                        pointRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'top' }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { precision: 0 }
                    }
                }
            }
        });

        // Bookings per package pie chart
            new Chart(document.getElementById("packageBookingsChart"), {
        type: 'pie',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.PackageLabels)),
            datasets: [{
                data: @Html.Raw(Json.Serialize(ViewBag.PackageCounts))
            }]
        },
        options: {
            plugins: {
                datalabels: {
                    color: '#fff',
                    font: {
                        weight: 'bold',
                        size: 14
                    },
                    formatter: (value, context) => {
                        let data = context.chart.data.datasets[0].data;
                        let total = data.reduce((a, b) => a + b, 0);
                        let percentage = (value / total * 100).toFixed(1) + "%";
                        return percentage;
                    }
                },
                legend: {
                    position: 'bottom'
                }
            }
        },
        plugins: [ChartDataLabels]
    });

        // Printing per service pie chart
        new Chart(document.getElementById("printingServiceChart"), {
            type: 'pie',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.PrintingServiceLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(ViewBag.PrintingServiceCounts))
                }]
            },
         options: {
            plugins: {
                datalabels: {
                    color: '#fff',
                    font: {
                        weight: 'bold',
                        size: 14
                    },
                    formatter: (value, context) => {
                        let data = context.chart.data.datasets[0].data;
                        let total = data.reduce((a, b) => a + b, 0);
                        let percentage = (value / total * 100).toFixed(1) + "%";
                        return percentage;
                    }
                },
                legend: {
                    position: 'bottom'
                }
            }
        },
        plugins: [ChartDataLabels]
    });
    </script>
