@model DgAPI.Models.StudioPackage

<h2>Delete Studio Package</h2>

<h3>Are you sure you want to delete this package?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">
            Package Name
        </dt>
        <dd class="col-sm-10">
            @Model.package_name
        </dd>
        <dt class="col-sm-2">
            Description
        </dt>
        <dd class="col-sm-10">
            @Model.package_description
        </dd>
        <dt class="col-sm-2">
            Price
        </dt>
        <dd class="col-sm-10">
            @Model.package_price
        </dd>
        <dt class="col-sm-2">
            Note
        </dt>
        <dd class="col-sm-10">
            @Model.package_note
        </dd>
        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            @Model.package_status
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="package_id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
