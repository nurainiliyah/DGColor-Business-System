@model DgAPI.Models.User

<h2>Delete User</h2>

<h3>Are you sure you want to delete this user?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">
            User Fullname
        </dt>
        <dd class="col-sm-10">
            @Model.user_fullname
        </dd>
        <dt class="col-sm-2">
            Username
        </dt>
        <dd class="col-sm-10">
            @Model.username
        </dd>
        <dt class="col-sm-2">
            Email
        </dt>
        <dd class="col-sm-10">
            @Model.email
        </dd>
        <dt class="col-sm-2">
            Role
        </dt>
        <dd class="col-sm-10">
            @Model.role
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="user_id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
